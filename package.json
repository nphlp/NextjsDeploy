{
    "name": "nextjs-deploy",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "prepare": "husky || true",
        "typegen": "next typegen",
        "dev": "next dev",
        "build": "next build",
        "build:analyze": "ANALYZE=true next build",
        "start": "next start",
        "auto": "bun install && bun run db:setup && bun run prisma:generate && bun run prisma:deploy && bun run fixtures:setup && bun run dev",
        "auto:start": "bun install && bun run db:setup && bun run prisma:generate && bun run prisma:deploy && bun run fixtures:setup && bun run build && bun run start",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --check --log-level warn",
        "format:fix": "prettier . --write --log-level error",
        "type": "tsc --noEmit",
        "checks": "bun run type && bun run lint:fix && bun run format:fix",
        "test:run": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "db:setup": "./scripts/db.sh setup",
        "db:reset": "./scripts/db.sh reset",
        "db:reload": "./scripts/db.sh reload",
        "db:execute": "./scripts/db.sh execute",
        "prisma:generate": "bunx prisma generate",
        "prisma:migrate": "bunx prisma migrate dev",
        "prisma:deploy": "bunx prisma migrate deploy",
        "prisma:reset": "bunx prisma migrate reset",
        "prisma:studio": "bunx prisma studio",
        "fixtures:setup": "bun scripts/fixtures.ts setup",
        "fixtures:reset": "bun scripts/fixtures.ts reset",
        "fixtures:reload": "bun scripts/fixtures.ts reload"
    },
    "dependencies": {
        "@better-auth/passkey": "^1.5.6",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "dotenv": "^17.3.1",
        "next": "16.2.1-canary.5",
        "pg": "^8.20.0",
        "prisma": "^7.5.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@base-ui/react": "^1.3.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/types": "^20.5.0",
        "@hookform/resolvers": "^5.2.2",
        "@marsidev/react-turnstile": "^1.4.2",
        "@next/bundle-analyzer": "^16.2.1",
        "@orpc/client": "^1.13.9",
        "@orpc/openapi": "^1.13.9",
        "@orpc/server": "^1.13.9",
        "@orpc/zod": "^1.13.9",
        "@playwright/test": "^1.58.2",
        "@react-email/components": "^1.0.10",
        "@react-email/render": "^2.0.4",
        "@scalar/api-reference-react": "^0.8.70",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@tailwindcss/postcss": "^4.2.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "better-auth": "^1.5.6",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "embla-carousel-react": "^8.6.0",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.4.0",
        "lodash": "^4.17.23",
        "lucide-react": "^0.563.0",
        "motion": "^12.38.0",
        "nodemailer": "^7.0.13",
        "nanoid": "^5.1.7",
        "nuqs": "^2.8.9",
        "otpauth": "^9.5.0",
        "postcss": "^8.5.8",
        "qrcode.react": "^4.2.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "react-day-picker": "^9.14.0",
        "semantic-release": "^25.0.3",
        "server-only": "^0.0.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.0",
        "zod": "^4.3.6"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": [
            "eslint --fix",
            "vitest related --run"
        ],
        "*.{js,ts,tsx,json,css,md,yml,yaml}": "prettier --write"
    }
}
